# ── Environment & secrets ─────────────────────────────────────────────────────
.env
*.pem
*.key

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
dist/
build/
.eggs/
*.egg
.Python
.venv/
venv/
env/
*.pyc

# ── Testing & coverage ────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
coverage.xml
*.xml
*.log

# ── Runtime outputs (go to metadata_logs/) ───────────────────────────────────
metadata_logs/schemas/
metadata_logs/schema_change_log.json
metadata_logs/evaluation_results.json
# Keep the metadata_logs/ directory itself tracked
!metadata_logs/.gitkeep

# ── Datasets / generated data ─────────────────────────────────────────────────
datasets/clean_orders/
datasets/**/*.parquet
datasets/**/*.delta
datasets/**/_delta_log/

# ── Delta Lake artifacts ──────────────────────────────────────────────────────
_delta_log/
*.delta/
spark-warehouse/

# ── Spark logs & temp ─────────────────────────────────────────────────────────
derby.log
metastore_db/
/tmp/

# ── Docker volumes ────────────────────────────────────────────────────────────
postgres-db-volume/
mongodb-data-volume/

# ── Empty scaffold dirs (tracked via .gitkeep, not raw folder) ───────────────
metadata/pipeline_configs/
metadata/rules/
metadata/schemas/

# ── Jupyter ───────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── IDE / OS ──────────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db
